# DischargePilot AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# Development: SQLite
DATABASE_URL=sqlite:///./dischargepilot.db
# Production: PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/dischargepilot

# ── Groq API Settings (primary AI provider) ──────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MAX_RETRIES=3
GROQ_RETRY_BASE_DELAY=2
GROQ_CACHE_ENABLED=true
OCR_ENABLED=true
OCR_PRIMARY_PROVIDER=groq
MIN_PAGE_TEXT_LENGTH=10

# ── Claude API Settings (secondary OCR fallback) ─────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=8192
CLAUDE_TEMPERATURE=0.1

# ── Agent Settings ────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=20
AGENT_TIMEOUT_SECONDS=300

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend (.env.local) ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=DischargePilot AI
NEXT_PUBLIC_ENV=development
