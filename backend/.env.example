# DischargePilot AI — Environment Variables
# Copy this file to .env and fill in your values

# Application
APP_NAME="DischargePilot AI"
APP_VERSION="2.0.0"
DEBUG=false
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite:///./dischargepilot.db
DATABASE_ECHO=false

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_VISION_MODEL=gemini-2.5-pro
GEMINI_TEXT_MODEL=gemini-2.5-pro

# Anthropic Claude API (primary Vision OCR provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_VISION_MODEL=claude-opus-4-8

# Processing
MAX_EXTRACTION_RETRIES=3
EXTRACTION_TIMEOUT_SECONDS=60
MIN_PAGE_TEXT_LENGTH=10
OCR_ENABLED=true
OCR_PRIMARY_PROVIDER=claude

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# API
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]
