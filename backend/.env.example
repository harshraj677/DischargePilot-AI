# DischargePilot AI — Environment Variables
# Copy this file to .env and fill in your values

# Application
APP_NAME="DischargePilot AI"
APP_VERSION="2.0.0"
DEBUG=false
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite:///./dischargepilot.db
DATABASE_ECHO=false

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Anthropic Claude API (single AI provider for the whole platform)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_VISION_MODEL=claude-opus-4-8
ANTHROPIC_TEXT_MODEL=claude-sonnet-4-6
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_RETRIES=3
CLAUDE_RETRY_BASE_DELAY=2.0
CLAUDE_RESPONSE_CACHE_ENABLED=true
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.60

# Processing
MAX_EXTRACTION_RETRIES=3
EXTRACTION_TIMEOUT_SECONDS=60
MIN_PAGE_TEXT_LENGTH=10
OCR_ENABLED=true
OCR_PRIMARY_PROVIDER=claude

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# API
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]
